generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  CUSTOMER
  STAFF
}

enum OrderStatus {
  NEW
  DEFICIENCY
  PENDING_PAYMENT
  PREPARED
  READY
  PICKED
  DELIVERED
  CANCELED
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  BANK_TRANSFER
  TELEBIRR
  CASH
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @unique() @db.VarChar(20)
  name      String?  @db.VarChar(100)
  email     String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("customers")
}

model Staff {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique() @db.VarChar(100)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  shopCode  String?  @map("shop_code") @db.VarChar(50)

  role        Role            @relation(fields: [roleId], references: [id])
  shop        Shop?           @relation(fields: [shopCode], references: [locationCode])
  verified    Order[]         @relation("verified_orders")
  canceled    Order[]         @relation("canceled_orders")

  statusChanges OrderStatusHistory[]

  @@map("staff")
}

model Rider {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  phone     String   @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[] @relation("rider_orders")

  @@map("riders")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique() @db.VarChar(50)
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  staff       Staff[]

  @@map("roles")
}

model Resource {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique() @db.VarChar(100)
  description String? @db.VarChar(255)

  permissions RolePermission[]

  @@map("resources")
}

model RolePermission {
  id         String @id @default(uuid()) @db.Uuid
  roleId     String @map("role_id") @db.Uuid
  resourceId String @map("resource_id") @db.Uuid
  canRead    Boolean @default(false) @map("can_read")
  canWrite   Boolean @default(false) @map("can_write")
  canDelete  Boolean @default(false) @map("can_delete")

  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique() @map("token_hash") @db.VarChar(255)
  familyId  String   @map("family_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userType  UserType @map("user_type")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, userType])
  @@index([familyId])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, code])
  @@map("otp_codes")
}

model Order {
  id          String   @id @default(uuid()) @db.Uuid
  orderNo     String   @unique() @map("order_no") @db.VarChar(50)
  shopCode    String   @map("shop_code") @db.VarChar(50)
  customerId  String   @map("customer_id") @db.Uuid
  status      OrderStatus @default(NEW)
  orderDate   DateTime @default(now()) @map("order_date")
  deliveryDate String?  @map("delivery_date") @db.VarChar(20)
  deliveryTimeWindow String? @map("delivery_time_window") @db.VarChar(50)
  deliveryMethod DeliveryMethod? @map("delivery_method")
  deliveryLocation String? @map("delivery_location") @db.VarChar(255)
  paymentMethod PaymentMethod? @map("payment_method")
  bankName      String?  @map("bank_name") @db.VarChar(100)
  paymentReferenceNo String? @map("payment_reference_no") @db.VarChar(100)
  paymentDescription String? @map("payment_description") @db.Text
  shipToName    String?  @map("ship_to_name") @db.VarChar(100)
  shipToEmail   String?  @map("ship_to_email") @db.VarChar(100)
  shipToPhone   String?  @map("ship_to_phone") @db.VarChar(20)
  shipToCity    String?  @map("ship_to_city") @db.VarChar(100)
  orderNote     String?  @map("order_note") @db.Text
  subtotal      Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @default(0) @db.Decimal(12, 2)
  deficiencyResponseDeadline DateTime? @map("deficiency_response_deadline")
  paymentDeadline           DateTime? @map("payment_deadline")
  verifiedBy   String?  @map("verified_by") @db.Uuid
  verifiedAt   DateTime? @map("verified_at")
  riderId      String?  @map("rider_id") @db.Uuid
  deliveredAt  DateTime? @map("delivered_at")
  canceledAt   DateTime? @map("canceled_at")
  canceledBy   String?  @map("canceled_by") @db.Uuid
  cancellationReason String? @map("cancellation_reason") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer  Customer  @relation(fields: [customerId], references: [id])
  shop      Shop      @relation(fields: [shopCode], references: [locationCode])
  verifiedByStaff Staff?  @relation("verified_orders", fields: [verifiedBy], references: [id])
  canceledByStaff Staff?  @relation("canceled_orders", fields: [canceledBy], references: [id])
  rider Rider? @relation("rider_orders", fields: [riderId], references: [id])

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  notifications Notification[]

  @@index([orderNo])
  @@index([shopCode])
  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@map("orders")
}

model OrderItem {
  id                 String   @id @default(uuid()) @db.Uuid
  orderId            String   @map("order_id") @db.Uuid
  itemCode           String   @map("item_code") @db.VarChar(50)
  itemDescription    String   @map("item_description") @db.VarChar(500)
  uom                String?  @db.VarChar(20)
  quantityRequested  Decimal  @map("quantity_requested") @db.Decimal(12, 3)
  quantityAvailable  Decimal? @map("quantity_available") @db.Decimal(12, 3)
  unitPrice          Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice         Decimal  @map("total_price") @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  fromStatus OrderStatus @map("from_status")
  toStatus   OrderStatus @map("to_status")
  changedBy  String?  @map("changed_by") @db.Uuid
  reason     String?  @db.Text
  changedAt  DateTime @default(now()) @map("changed_at")

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByStaff Staff? @relation(fields: [changedBy], references: [id])

  @@index([orderId])
  @@index([changedAt])
  @@map("order_status_history")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  type      String   @db.VarChar(50)
  channel   String   @db.VarChar(20)
  message   String   @db.Text
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("notifications")
}

// ============================================================
// PRODUCT MODULE — matches old dailyMart schema EXACTLY
// ============================================================

model Category {
  id         Int       @id @default(autoincrement())
  categoryId String    @map("category_id") @db.VarChar(50)
  titleEn    String    @map("title_en") @db.VarChar(200)
  titleAm    String    @map("title_am") @db.VarChar(200)
  image      String?   @db.VarChar(500)
  createdBy  Int?      @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  productGroups ProductGroup[]
  items         Item[]

  @@index([titleEn])
  @@index([titleAm])
  @@map("category")
}

model ProductGroup {
  id         Int       @id @default(autoincrement())
  productId  String    @map("product_id") @db.VarChar(50)
  categoryId Int       @map("category_id")
  titleEn    String    @map("title_en") @db.VarChar(200)
  titleAm    String    @map("title_am") @db.VarChar(200)
  image      String?   @db.VarChar(500)
  createdBy  Int?      @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id])
  brands   Brand[]
  items    Item[]

  @@index([categoryId])
  @@index([titleEn])
  @@index([titleAm])
  @@map("product_group")
}

model Brand {
  id        Int       @id @default(autoincrement())
  brandId   String    @map("brand_id") @db.VarChar(50)
  productId Int       @map("product_id")
  titleEn   String    @map("title_en") @db.VarChar(200)
  titleAm   String    @map("title_am") @db.VarChar(200)
  image     String?   @db.VarChar(500)
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")

  productGroup ProductGroup @relation(fields: [productId], references: [id])
  items        Item[]

  @@index([productId])
  @@index([titleEn])
  @@index([titleAm])
  @@map("brand")
}

model Item {
  id               Int      @id @default(autoincrement())
  itemId           String   @map("item_id") @db.VarChar(50)
  categoryId       Int      @map("category_id")
  productId        Int      @map("product_id")
  brandId          Int      @map("brand_id")
  titleEn          String   @map("title_en") @db.VarChar(200)
  titleAm          String   @map("title_am") @db.VarChar(200)
  image            String?  @db.VarChar(500)
  specificationsEn String?  @map("specifications_en") @db.Text
  specificationsAm String?  @map("specifications_am") @db.Text
  itemCode1        String?  @map("item_code1") @db.VarChar(50)
  createdBy        Int?     @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  category      Category      @relation(fields: [categoryId], references: [id])
  productGroup  ProductGroup  @relation(fields: [productId], references: [id])
  brand         Brand         @relation(fields: [brandId], references: [id])
  prices        ItemPrice[]
  priceDiscounts PriceDiscount[]
  comboHeaders  ComboHeader[]
  comboLines    ComboLine[]
  topItems      TopItem[]

  @@index([categoryId])
  @@index([productId])
  @@index([brandId])
  @@index([titleEn])
  @@index([titleAm])
  @@map("item")
}

model ItemPrice {
  id        Int       @id @default(autoincrement())
  priceId   String?   @map("price_id") @db.VarChar(50)
  itemId    Int       @map("item_id")
  price     Decimal   @db.Decimal(12, 2)
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  customerNo String?  @map("customer_no") @db.VarChar(50)
  uom       String?   @db.VarChar(20)

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@map("price")
}

model PriceDiscount {
  id         Int      @id @default(autoincrement())
  discountId String?  @map("discount_id") @db.VarChar(50)
  itemId     Int      @map("item_id")
  discountPer Decimal @map("discount_per") @db.Decimal(5, 2)
  uom        String?  @db.VarChar(20)

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@map("price_discount")
}

model ComboHeader {
  id          Int       @id @default(autoincrement())
  itemId      Int       @map("item_id")
  description String?   @db.VarChar(500)
  price       Decimal   @db.Decimal(12, 2)
  active      Boolean   @default(true)

  item  Item       @relation(fields: [itemId], references: [id])
  lines ComboLine[]

  @@index([itemId])
  @@map("combo_header")
}

model ComboLine {
  id             Int     @id @default(autoincrement())
  headerNumber   Int     @map("header_number")
  itemId         Int     @map("item_id")
  itemDescription String? @map("item_description") @db.VarChar(500)
  quantity       Decimal @db.Decimal(12, 2)

  header ComboHeader @relation(fields: [headerNumber], references: [id], onDelete: Cascade)
  item   Item        @relation(fields: [itemId], references: [id])

  @@index([headerNumber])
  @@index([itemId])
  @@map("combo_line")
}

model TopItem {
  id     Int @id @default(autoincrement())
  itemId Int @map("item_id")

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@map("top_item")
}

model NavSyncLog {
  id           Int       @id @default(autoincrement())
  startedAt    DateTime  @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  rowsSynced   Int?      @map("rows_synced")
  status       String    @db.VarChar(20)
  errorMessage String?   @map("error_message") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([startedAt])
  @@map("nav_sync_logs")
}

model LandMark {
  code      String  @id @db.VarChar(50)
  titleEn   String  @map("title_en") @db.VarChar(200)
  titleAm   String  @map("title_am") @db.VarChar(200)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  createdAt DateTime @default(now()) @map("created_at")

  landMarkPrices LandMarkPrice[]

  @@map("land_marks")
}

model Shop {
  locationCode String  @id @map("location_code") @db.VarChar(50)
  titleEn      String  @map("title_en") @db.VarChar(200)
  titleAm      String  @map("title_am") @db.VarChar(200)
  address      String? @db.VarChar(500)
  phone        String? @db.VarChar(20)
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  createdAt    DateTime @default(now()) @map("created_at")

  staff         Staff[]
  orders        Order[]
  landMarkPrices LandMarkPrice[]

  @@map("shops")
}

model DeliveryDate {
  id      String @id @default(uuid()) @db.Uuid
  titleEn String @map("title_en") @db.VarChar(200)
  titleAm String @map("title_am") @db.VarChar(200)

  landMarkPrices LandMarkPrice[]

  @@map("delivery_dates")
}

model TimeRange {
  id        String @id @default(uuid()) @db.Uuid
  timeRange String @map("time_range") @db.VarChar(50)

  @@map("time_ranges")
}

model LandMarkPrice {
  id           String   @id @default(uuid()) @db.Uuid
  dateId       String   @map("date_id") @db.Uuid
  timeRange    String   @map("time_range") @db.VarChar(50)
  landMarkCode String  @map("land_mark_code") @db.VarChar(50)
  shopCode     String   @map("shop_code") @db.VarChar(50)
  price        Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  date      DeliveryDate @relation(fields: [dateId], references: [id])
  landMark  LandMark     @relation(fields: [landMarkCode], references: [code])
  shop      Shop         @relation(fields: [shopCode], references: [locationCode])

  @@index([dateId])
  @@index([landMarkCode])
  @@index([shopCode])
  @@map("land_mark_prices")
}
